<!DOCTYPE html><html lang="en" data-theme="dark"><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8"><link rel="stylesheet" type="text/css" href="cid:css-9189ad8b-f53d-4ea7-a467-29b454bbc9d1@mhtml.blink" />

<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>padel-live-bracket</title>
<link href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,700&amp;f[]=cabinet-grotesk@700,800&amp;display=swap" rel="stylesheet">

</head>
<body>
<div class="app">
  <div class="topbar">
    <div class="brand">
      <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="18" cy="18" r="16" stroke="currentColor" stroke-width="2"></circle><path d="M10 18 Q18 8 26 18 Q18 28 10 18Z" fill="currentColor" opacity=".18"></path><path d="M10 18 Q18 8 26 18 Q18 28 10 18Z" stroke="currentColor" stroke-width="1.5"></path><circle cx="18" cy="18" r="2.5" fill="currentColor"></circle></svg>
      <h1>Greencastle Padel Live</h1>
    </div>
    <div class="actions">
      <button class="btn" id="themeBtn">Theme</button>
      <button class="btn" id="copyBtn">Copy Share Link</button>
      <button class="btn" id="seedBtn">Load Sample Teams</button>
    </div>
  </div>

  <div class="hero">
    <h2>Live tournament bracket</h2>
    <p>Everyone with the same tournament ID can enter results and watch scores update live.</p>
  </div>

  <div class="notice"><strong>Important:</strong> this version is built for Firebase Firestore realtime sync. Add your Firebase project details in the setup section below, publish the file, and everyone with the link will see live updates.</div>

  <div class="setup">
    <h3>Setup</h3>
    <ol>
      <li>Create a free Firebase project and enable <strong>Cloud Firestore</strong>.[web:25]</li>
      <li>Replace the <strong>firebaseConfig</strong> block in this file with your project credentials from Firebase project settings.[web:25]</li>
      <li>Set Firestore rules for testing while you get started, then tighten them later.</li>
      <li>Open the app with a URL like <strong>?tournament=week2</strong>. Everyone using the same tournament ID shares the same live bracket.</li>
    </ol>
    <div class="code">Temporary Firestore test rules:
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /tournaments/{id} {
      allow read, write: if true;
    }
  }
}</div>
  </div>

  <div class="statusbar">
    <div class="pill">Tournament ID: <strong id="tourId">week2</strong></div>
    <div class="pill live" id="syncState">● Live sync connected</div>
  </div>

  <div class="bracket">
    <div class="round"><div class="round-label">Round 1</div>
      <div class="match" id="m1"><div class="match-head">Court 5</div><button class="team" data-match="m1" data-slot="t1"><span class="name" id="m1-t1-name">Harry &amp; Keith</span><span class="score" id="m1-t1-score">—</span></button><button class="team" data-match="m1" data-slot="t2"><span class="name" id="m1-t2-name">Ron &amp; Conor</span><span class="score" id="m1-t2-score">—</span></button></div>
      <div class="match" id="m2"><div class="match-head">Court 9</div><button class="team" data-match="m2" data-slot="t1"><span class="name" id="m2-t1-name">Cathal &amp; Eoin</span><span class="score" id="m2-t1-score">—</span></button><button class="team" data-match="m2" data-slot="t2"><span class="name" id="m2-t2-name">Paddy &amp; The Apprentice</span><span class="score" id="m2-t2-score">—</span></button></div>
      <div class="match" id="m3"><div class="match-head">Court 10</div><button class="team" data-match="m3" data-slot="t1"><span class="name" id="m3-t1-name">Sean &amp; McD</span><span class="score" id="m3-t1-score">—</span></button><button class="team" data-match="m3" data-slot="t2"><span class="name" id="m3-t2-name">Cahir &amp; Luke</span><span class="score" id="m3-t2-score">—</span></button></div>
      <div class="match" id="m4"><div class="match-head">Court 5</div><button class="team" data-match="m4" data-slot="t1"><span class="name" id="m4-t1-name">Spare Pair 1</span><span class="score" id="m4-t1-score">—</span></button><button class="team" data-match="m4" data-slot="t2"><span class="name" id="m4-t2-name">Spare Pair 2</span><span class="score" id="m4-t2-score">—</span></button></div>
    </div>
    <div class="round"><div class="round-label">Round 2</div>
      <div class="match" id="m5"><div class="match-head">Winner 1 vs Winner 2</div><button class="team" data-match="m5" data-slot="t1"><span class="name" id="m5-t1-name">W: Match 1</span><span class="score" id="m5-t1-score">—</span></button><button class="team" data-match="m5" data-slot="t2"><span class="name" id="m5-t2-name">W: Match 2</span><span class="score" id="m5-t2-score">—</span></button></div>
      <div class="match" id="m6"><div class="match-head">Winner 3 vs Winner 4</div><button class="team" data-match="m6" data-slot="t1"><span class="name" id="m6-t1-name">W: Match 3</span><span class="score" id="m6-t1-score">—</span></button><button class="team" data-match="m6" data-slot="t2"><span class="name" id="m6-t2-name">W: Match 4</span><span class="score" id="m6-t2-score">—</span></button></div>
      <div class="match" id="m7"><div class="match-head">Loser 1 vs Loser 2</div><button class="team" data-match="m7" data-slot="t1"><span class="name" id="m7-t1-name">L: Match 1</span><span class="score" id="m7-t1-score">—</span></button><button class="team" data-match="m7" data-slot="t2"><span class="name" id="m7-t2-name">L: Match 2</span><span class="score" id="m7-t2-score">—</span></button></div>
      <div class="match" id="m8"><div class="match-head">Loser 3 vs Loser 4</div><button class="team" data-match="m8" data-slot="t1"><span class="name" id="m8-t1-name">L: Match 3</span><span class="score" id="m8-t1-score">—</span></button><button class="team" data-match="m8" data-slot="t2"><span class="name" id="m8-t2-name">L: Match 4</span><span class="score" id="m8-t2-score">—</span></button></div>
    </div>
    <div class="round"><div class="round-label">Round 3</div>
      <div class="match final" id="m9"><div class="match-head">Final · Winners of 5 &amp; 6</div><button class="team" data-match="m9" data-slot="t1"><span class="name" id="m9-t1-name">W: Match 5</span><span class="score" id="m9-t1-score">—</span></button><button class="team" data-match="m9" data-slot="t2"><span class="name" id="m9-t2-name">W: Match 6</span><span class="score" id="m9-t2-score">—</span></button></div>
      <div class="match third" id="m10"><div class="match-head">3rd Place · Losers of 5 &amp; 6</div><button class="team" data-match="m10" data-slot="t1"><span class="name" id="m10-t1-name">L: Match 5</span><span class="score" id="m10-t1-score">—</span></button><button class="team" data-match="m10" data-slot="t2"><span class="name" id="m10-t2-name">L: Match 6</span><span class="score" id="m10-t2-score">—</span></button></div>
      <div class="match fifth" id="m11"><div class="match-head">5th Place · Winners of 7 &amp; 8</div><button class="team" data-match="m11" data-slot="t1"><span class="name" id="m11-t1-name">W: Match 7</span><span class="score" id="m11-t1-score">—</span></button><button class="team" data-match="m11" data-slot="t2"><span class="name" id="m11-t2-name">W: Match 8</span><span class="score" id="m11-t2-score">—</span></button></div>
      <div class="match" id="m12"><div class="match-head">7th Place · Losers of 7 &amp; 8</div><button class="team" data-match="m12" data-slot="t1"><span class="name" id="m12-t1-name">L: Match 7</span><span class="score" id="m12-t1-score">—</span></button><button class="team" data-match="m12" data-slot="t2"><span class="name" id="m12-t2-name">L: Match 8</span><span class="score" id="m12-t2-score">—</span></button></div>
    </div>
  </div>

  <div class="standings">
    <div class="standingsHead"><h3>Placings</h3><span class="muted">Updates live for everyone on the same tournament ID</span></div>
    <table><thead><tr><th>Place</th><th>Pair</th><th>Status</th></tr></thead><tbody id="standingsBody"><tr><td colspan="3" class="muted">No final placings yet.</td></tr></tbody></table>
  </div>
</div>

<div class="modalWrap" id="modalWrap">
  <div class="modal">
    <h3 id="modalTitle">Enter result</h3>
    <p class="muted" id="modalSub">Scores and winner will sync live.</p>
    <div class="grid2">
      <div class="field"><label id="label1">Team 1</label><input id="score1" type="number" min="0" max="99" placeholder="0"></div>
      <div class="field"><label id="label2">Team 2</label><input id="score2" type="number" min="0" max="99" placeholder="0"></div>
    </div>
    <p class="muted" style="margin-bottom:8px">Winner</p>
    <div class="winnerBtns">
      <button class="winnerBtn" id="winner1"></button>
      <button class="winnerBtn" id="winner2"></button>
    </div>
    <div class="modalActions"><button class="btn" id="cancelBtn">Cancel</button><button class="btn primary" id="saveBtn">Save result</button></div>
  </div>
</div>



</body></html>
