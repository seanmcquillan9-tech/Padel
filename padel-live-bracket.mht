@charset "utf-8";

:root, [data-theme="light"] { --color-bg: #f7f6f2; --color-surface: #f9f8f5; --color-surface-2: #fbfbf9; --color-surface-offset: #f3f0ec; --color-border: #d4d1ca; --color-divider: #dcd9d5; --color-text: #28251d; --color-text-muted: #7a7974; --color-text-faint: #bab9b4; --color-primary: #01696f; --color-primary-hover: #0c4e54; --color-winner: #01696f; --color-loser: #8b3a3a; --color-final: #8a6200; --color-third: #2e5c10; --color-fifth: #4a3a70; --shadow-sm: 0 1px 2px oklch(0.2 0.01 80/0.06); --shadow-md: 0 4px 12px oklch(0.2 0.01 80/0.08); --shadow-lg: 0 12px 32px oklch(0.2 0.01 80/0.12); --radius-md: .5rem; --radius-lg: .75rem; --radius-xl: 1rem; --transition: 180ms cubic-bezier(.16,1,.3,1); --font-display: 'Cabinet Grotesk',sans-serif; --font-body: 'Satoshi',sans-serif; }

[data-theme="dark"] { --color-bg: #171614; --color-surface: #1c1b19; --color-surface-2: #201f1d; --color-surface-offset: #22211f; --color-border: #393836; --color-divider: #262523; --color-text: #cdccca; --color-text-muted: #797876; --color-text-faint: #5a5957; --color-primary: #4f98a3; --color-primary-hover: #227f8b; --color-winner: #4f98a3; --color-loser: #c47575; --color-final: #d4a800; --color-third: #6daa45; --color-fifth: #9b7de0; --shadow-sm: 0 1px 2px oklch(0 0 0/.2); --shadow-md: 0 4px 12px oklch(0 0 0/.3); --shadow-lg: 0 12px 32px oklch(0 0 0/.4); }

* { box-sizing: border-box; margin: 0px; padding: 0px; }

body { font-family: var(--font-body); background: var(--color-bg); color: var(--color-text); min-height: 100vh; }

button, input { font: inherit; }

button { cursor: pointer; }

.app { max-width: 1180px; margin: 0px auto; padding: 24px 16px 48px; }

.topbar { display: flex; justify-content: space-between; gap: 12px; align-items: center; flex-wrap: wrap; margin-bottom: 24px; }

.brand { display: flex; gap: 12px; align-items: center; }

.brand svg { width: 34px; height: 34px; color: var(--color-primary); }

.brand h1 { font-family: var(--font-display); font-size: 1.35rem; }

.actions { display: flex; gap: 8px; flex-wrap: wrap; }

.btn { border: 1px solid var(--color-border); background: var(--color-surface); color: var(--color-text); padding: 10px 14px; border-radius: 12px; }

.btn:hover { background: var(--color-surface-offset); }

.btn.primary { background: var(--color-primary); color: rgb(255, 255, 255); border-color: var(--color-primary); }

.btn.primary:hover { background: var(--color-primary-hover); }

.hero { text-align: center; margin-bottom: 18px; }

.hero h2 { font-family: var(--font-display); font-size: clamp(1.6rem, 3vw, 2.4rem); }

.hero p { color: var(--color-text-muted); margin-top: 6px; }

.notice, .setup, .standings { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 16px; box-shadow: var(--shadow-sm); }

.notice { padding: 14px 16px; margin-bottom: 16px; }

.notice strong { color: var(--color-primary); }

.setup { padding: 18px; margin-bottom: 22px; }

.setup h3 { font-family: var(--font-display); margin-bottom: 10px; }

.setup p, .setup li { color: var(--color-text-muted); }

.setup ol { padding-left: 18px; display: grid; gap: 8px; }

.code { background: var(--color-surface-offset); border: 1px solid var(--color-border); padding: 12px; border-radius: 12px; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.85rem; overflow: auto; white-space: pre-wrap; margin-top: 12px; }

.statusbar { display: flex; gap: 12px; flex-wrap: wrap; align-items: center; margin-bottom: 18px; }

.pill { padding: 8px 12px; border-radius: 999px; background: var(--color-surface); border: 1px solid var(--color-border); font-size: 0.85rem; }

.pill.live { color: var(--color-winner); }

.bracket { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }

.round { display: flex; flex-direction: column; gap: 12px; }

.round-label { text-align: center; text-transform: uppercase; letter-spacing: 0.08em; font-size: 0.75rem; color: var(--color-text-muted); padding-bottom: 8px; border-bottom: 1px solid var(--color-divider); }

.match { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 14px; overflow: hidden; box-shadow: var(--shadow-sm); }

.match-head { padding: 7px 10px; background: var(--color-surface-offset); border-bottom: 1px solid var(--color-border); font-size: 0.72rem; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em; }

.team { display: flex; justify-content: space-between; gap: 8px; align-items: center; padding: 12px; border: 0px; background: none; width: 100%; text-align: left; color: inherit; }

.team + .team { border-top: 1px solid var(--color-divider); }

.team:hover { background: var(--color-surface-offset); }

.team.winner { background: color-mix(in oklch,var(--color-winner) 12%,var(--color-surface)); }

.team.loser { background: color-mix(in oklch,var(--color-loser) 8%,var(--color-surface)); opacity: 0.78; }

.name { font-size: 0.9rem; font-weight: 500; }

.score { font-variant-numeric: tabular-nums; font-weight: 700; min-width: 22px; text-align: right; }

.final .match-head { background: color-mix(in oklch,var(--color-final) 18%,var(--color-surface-offset)); color: var(--color-final); }

.third .match-head { background: color-mix(in oklch,var(--color-third) 18%,var(--color-surface-offset)); color: var(--color-third); }

.fifth .match-head { background: color-mix(in oklch,var(--color-fifth) 18%,var(--color-surface-offset)); color: var(--color-fifth); }

.modalWrap { position: fixed; inset: 0px; background: oklch(0 0 0 / 0.5); display: none; align-items: center; justify-content: center; padding: 20px; z-index: 20; }

.modalWrap.open { display: flex; }

.modal { width: min(460px, 100%); background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 18px; padding: 18px; box-shadow: var(--shadow-lg); }

.modal h3 { font-family: var(--font-display); margin-bottom: 6px; }

.muted { color: var(--color-text-muted); }

.grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin: 14px 0px; }

.field label { display: block; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); margin-bottom: 6px; }

.field input { width: 100%; padding: 11px 12px; border-radius: 12px; border: 1px solid var(--color-border); background: var(--color-surface-offset); color: var(--color-text); outline: none; }

.winnerBtns { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin: 10px 0px 14px; }

.winnerBtn { padding: 12px; border: 1px solid var(--color-border); border-radius: 12px; background: var(--color-surface-offset); }

.winnerBtn.active { border-color: var(--color-primary); background: color-mix(in oklch,var(--color-primary) 14%,var(--color-surface)); }

.modalActions { display: flex; justify-content: flex-end; gap: 8px; }

.standings { margin-top: 22px; overflow: hidden; }

.standingsHead { padding: 14px 16px; border-bottom: 1px solid var(--color-divider); display: flex; justify-content: space-between; gap: 12px; align-items: center; }

.standingsHead h3 { font-family: var(--font-display); }

table { width: 100%; border-collapse: collapse; }

th, td { padding: 12px 16px; border-bottom: 1px solid var(--color-divider); text-align: left; }

th { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); background: var(--color-surface-offset); }

tr:last-child td { border-bottom: none; }

@media (max-width: 900px) {
  .bracket { grid-template-columns: 1fr 1fr; }
}

@media (max-width: 560px) {
  .bracket { grid-template-columns: 1fr; }
}
